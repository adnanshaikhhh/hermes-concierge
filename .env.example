# ── Supabase ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── MiniMax M3 (AI Fulfillment) ──────────────────────
# Required for real AI delivery; if absent, system uses
# a deterministic local fallback (looks polished but
# identical structure across briefs).
MINIMAX_API_KEY=<your-minimax-api-key>

# ── Resend (Email Notifications) ─────────────────────
# Optional. If absent or "re_placeholder", email is stubbed.
RESEND_API_KEY=re_placeholder
FROM_EMAIL=noreply@hermesconcierge.com

# ── App URL ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://hermes-concierge-ten.vercel.app
