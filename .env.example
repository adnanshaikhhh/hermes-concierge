# ── Supabase ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── MiniMax M3 (AI Fulfillment) ──────────────────────
# Primary: NVIDIA NIM (OpenAI-compatible). Set NVIDIA_API_KEY in Vercel
# to use real M3 inference ("minimaxai/minimax-m3"). If both keys are
# unset/missing, the system uses a deterministic local fallback and logs
# a loud warning.
NVIDIA_API_KEY=nvapi-...
# Optional override; defaults to https://integrate.api.nvidia.com/v1
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Legacy alias (still honoured if NVIDIA_API_KEY is unset).
MINIMAX_API_KEY=<your-minimax-api-key>

# ── Resend (Email Notifications) ─────────────────────
# Optional. If absent or "re_placeholder", email is stubbed.
RESEND_API_KEY=re_placeholder
FROM_EMAIL=noreply@hermesconcierge.com

# ── App URL ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://hermes-concierge-ten.vercel.app
